# Copy to backend/.env (backend auto-loads via python-dotenv).

# ── Gemini 2.5 Flash ──
# Required for real LLM reasoning. Leave empty for mock mode.
# Get one: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ── Google OAuth ──
# Required for "Sign in with Google". Without these, the frontend shows a
# dev-bypass login form (local use only, blocked when ENV=production).
#
# Setup (local):
#   1. https://console.cloud.google.com/ → APIs & Services → Credentials
#   2. "Create Credentials" → "OAuth client ID" → Application type: Web application
#   3. Authorized JavaScript origins:  http://localhost:5173
#   4. Authorized redirect URIs:       http://localhost:8000/auth/google/callback
#   5. Copy Client ID + Client Secret below.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
OAUTH_REDIRECT_URI=http://localhost:8000/auth/google/callback

# Random 48+ char string. Signs the session cookie.
# Generate: python -c "import secrets; print(secrets.token_urlsafe(48))"
SESSION_SECRET=

# URL the backend redirects to after successful Google login.
FRONTEND_URL=http://localhost:5173

# Comma-separated list of allowed frontend origins.
CORS_ORIGINS=http://localhost:5173

# Set to "production" to disable the dev-bypass route and enforce HTTPS-only cookies.
ENV=development
